# Normalize line endings
* text=auto

# Force LF for cross-platform consistency
*.cs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows files (keep CRLF if needed)
*.sln text eol=crlf
*.bat text eol=crlf

# Binary files (never modify line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.dll binary
*.exe binary

# Prevent Git from trying to diff binaries
*.pdf binary